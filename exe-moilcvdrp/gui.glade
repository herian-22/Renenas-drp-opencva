<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.20"/>
  <object class="GtkWindow" id="main_window">
    <property name="can_focus">False</property>
    <property name="title" translatable="yes">DRP-AI Moildev GUI</property>
    <property name="default_width">1280</property>
    <property name="default_height">800</property>
    <signal name="destroy" handler="on_window_destroy" swapped="no"/>
    <child>
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkEventBox" id="event_box_img">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <signal name="button-press-event" handler="on_mouse_down" swapped="no"/>
            <signal name="button-release-event" handler="on_mouse_up" swapped="no"/>
            <signal name="motion-notify-event" handler="on_mouse_move" swapped="no"/>
            <child>
              <object class="GtkImage" id="img_display">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object class="GtkButtonBox">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="layout_style">spread</property>
            <child>
              <object class="GtkButton" id="btn_main">
                <property name="label" translatable="yes">MAIN</property>
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <signal name="clicked" handler="on_btn_main_clicked" swapped="no"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="btn_orig">
                <property name="label" translatable="yes">ORIGINAL</property>
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <signal name="clicked" handler="on_btn_orig_clicked" swapped="no"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="btn_pano">
                <property name="label" translatable="yes">PANORAMA</property>
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <signal name="clicked" handler="on_btn_pano_clicked" swapped="no"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="btn_grid">
                <property name="label" translatable="yes">GRID</property>
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <signal name="clicked" handler="on_btn_grid_clicked" swapped="no"/>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="btn_ptz">
                <property name="label" translatable="yes">PTZ (Single)</property>
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <signal name="clicked" handler="on_btn_ptz_clicked" swapped="no"/>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">1</property>
          </packing>
        </child>
      </object>
    </child>
  </object>
</interface>